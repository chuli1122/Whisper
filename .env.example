# 数据库
SUPABASE_URL=postgresql://user:password@localhost:5432/whisper

# 向量嵌入（SiliconFlow）
SILICONFLOW_API_KEY=<siliconflow-api-key>

# 认证
WHISPER_PASSWORD=<local-dev-password>
WHISPER_SECRET=<jwt-secret>

# 服务端口
PORT=8002
HOST=0.0.0.0

# Telegram Bot
TELEGRAM_BOT_TOKEN_ACHENG=<telegram-bot-token>
TELEGRAM_BOT_TOKEN_AHUAI=<telegram-bot-token>
TELEGRAM_CHAT_ID=<telegram-chat-id>
WEBHOOK_BASE_URL=http://localhost:8002
MINI_APP_URL=http://localhost:8002/miniapp/#/cot
MINI_APP_BASE_URL=http://localhost:8002/miniapp/

# Jina AI（网页抓取）
JINA_API_KEYS=<jina-api-key-1>,<jina-api-key-2>

# Tavily（互联网搜索）
TAVILY_API_KEY=<tavily-api-key>
