# 数据库
SUPABASE_URL=postgresql://user:password@localhost:5432/whisper

# 向量嵌入（SiliconFlow）
SILICONFLOW_API_KEY=sk-xxx

# 认证
WHISPER_PASSWORD=your_password
WHISPER_SECRET=your_jwt_secret

# 服务端口
PORT=8002
HOST=0.0.0.0

# Telegram Bot
TELEGRAM_BOT_TOKEN_ACHENG=your_bot_token
TELEGRAM_BOT_TOKEN_AHUAI=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
WEBHOOK_BASE_URL=https://your-domain.com

# Jina AI（网页抓取）
JINA_API_KEYS=key1,key2

# Tavily（互联网搜索）
TAVILY_API_KEY=tvly-xxx
